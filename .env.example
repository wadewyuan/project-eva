# LLM 服务配置
LLM_BASE_URL=http://localhost:8080/v1
LLM_MODEL=Qwen-3.5-9B
LLM_API_KEY=your_api_key_here
LLM_TEMPERATURE=0.8
LLM_MAX_TOKENS=your_max_tokens_here

# LLM 小模型（用于 tone detection，未配置则使用主模型相同配置）
LLM_SMALL_BASE_URL=
LLM_SMALL_MODEL=
LLM_SMALL_API_KEY=

# 应用配置
MAX_CONTEXT_MESSAGES=20
DB_PATH=./data/eva.db
DEFAULT_PERSONA_PATH=./config/default_persona.yaml
PERSONAS_DIR=./personas

# TTS - 本地 VoxCPM（默认）
TTS_PROVIDER=voxcpm
TTS_VOXCPM_MODEL_SOURCE=modelscope
TTS_VOXCPM_CACHE_DIR=~/.cache/modelscope
TTS_VOXCPM_CFG_VALUE=2.0
TTS_VOXCPM_INFERENCE_TIMESTEPS=10
TTS_VOXCPM_LOAD_DENOISER=False
